#!/bin/bash
# Interactive script to run wgs_prism2 on a WGS MGI G99 / T1+ Sequencing Run.

module purge && module load Miniforge3/24.9.0-0
module load snakemake/7.32.3-foss-2023a-Python-3.11.6
WGS_PRISM_BIN=/projects/2023_sequence_production/wgs_prism
cd "$WGS_PRISM_BIN" || exit 1

SEQ_PROJECT=2026_sequence_production_a
SMK_CONFIG_DIR=config/slurm/eRI
SEQ_ROOT=/projects/$SEQ_PROJECT/run_data
SEQ_POSTPROCESS_ROOT=/scratch/$SEQ_PROJECT/postprocessing/mgi

# MGI G99 / T1+ writes one multiplexed fastq per lane. Multi-lane is future work.
LANE=L01


get_run_opts() {
   echo "Running MGI Sequence Production and MultiQC Report Generation."

   ####### get and check RUN
   while [ 1 ]; do
      echo "Please give the full name of the MGI run / flowcell ID (e.g. FT150034703): "
      echo
      read_answer_with_default $ARGRUN
      RUN=$answer

      if [ -n "$RUN" ] && [ -d "$SEQ_ROOT/$RUN" ]; then
         break
      fi
      echo "Sorry, can't find $RUN under $SEQ_ROOT"
   done

   echo "Will process $SEQ_ROOT/$RUN"
   echo

   ####### machine type comes from RunInfoMetrics.csv; MGI writes no RunInfo.xml
   RUN_INFO=$SEQ_ROOT/$RUN/Metrics/${RUN}_RunInfoMetrics.csv
   if [ ! -f "$RUN_INFO" ]; then
      echo "Error: $RUN_INFO not found, cannot determine machine type. Quitting."
      exit 1
   fi

   # e.g. "Sequencer ID,INV-MGI-G99" -> g99
   RUN_TYPE=$(grep '^Sequencer ID,' "$RUN_INFO" | head -1 | cut -d, -f2 | tr -d '\r' |
      sed 's/^INV-MGI-//' | tr 'A-Z' 'a-z')
   if [ -z "$RUN_TYPE" ]; then
      echo "Error: could not determine machine type from $RUN_INFO (no 'Sequencer ID' row). Quitting."
      exit 1
   fi
   echo "Machine type: $RUN_TYPE"
   mkdir -p $SEQ_POSTPROCESS_ROOT/$RUN_TYPE

   ####### the sample sheet lives outside the run folder on MGI, so ask for it
   while [ 1 ]; do
      echo
      echo "Please give the full path to the Illumina-format sample sheet for this run"
      echo "(e.g. /projects/2023-bjp-sandbox/testing/samplesheets/$RUN.csv): "
      read_answer_with_default ""
      SAMPLE_SHEET=$answer

      if [ -n "$SAMPLE_SHEET" ] && [ -f "$SAMPLE_SHEET" ]; then
         break
      fi
      echo "Sorry, can't find a sample sheet at '$SAMPLE_SHEET'"
   done

   ######## confirm output folder ###########
   # set up output folder

   while [ 1 ]; do
      echo "Please specify the output folder, or press Enter to use the default: $SEQ_POSTPROCESS_ROOT/$RUN_TYPE/$RUN "
      read_answer_with_default $SEQ_POSTPROCESS_ROOT/$RUN_TYPE/$RUN
      NEW_ROOT=$answer
      if [ -d $NEW_ROOT ]; then
         echo
         echo "Warning: $NEW_ROOT already exists, use anyway? (y/n; default=y)"
         read_answer_with_default y
         if [ "$answer" == "y" ]; then
            OUTPUT_ROOT=$NEW_ROOT
            break
         fi
      else
         mkdir -p $NEW_ROOT
         if [ -d $NEW_ROOT ]; then
            OUTPUT_ROOT=$NEW_ROOT
            break
         fi
      fi
   done

   echo
   echo "Will use run $SEQ_ROOT/$RUN"
   echo "Will use lane $LANE"
   echo "Will use sample sheet $SAMPLE_SHEET"
   echo "Will use output folder $OUTPUT_ROOT"
   echo "Proceed with sequence production and MultiQC report generation? (y/n; default=y)"
   read_answer_with_default y
   if [ "$answer" != "y" ]; then
      echo "OK, quitting..."
      exit 0
   else
      echo
      run_sequencer_qc
   fi

}


read_answer_with_default() {
   read answer
   if [ -z "$answer" ]; then
      answer=$@
      echo "Default response: $answer"
   fi
}


get_opts() {
   ARGRUN=""
   help_text="
This script is called by run_wgs_qc.
"
   while getopts ":hr:" opt; do
      case $opt in
      h)
         echo -e $help_text
         exit 0
         ;;
      r)
         ARGRUN=$OPTARG
         ;;
      \?)
         echo "Invalid option: -$OPTARG" >&2
         exit 1
         ;;
      :)
         echo "Option -$OPTARG requires an argument." >&2
         exit 1
         ;;
      esac
   done

   shift $((OPTIND - 1))

}

run_sequencer_qc() {

   # MGI writes no RTAComplete.txt. Sequencing is finished when RunInfoMetrics
   # reports success, and the fastq has landed when FileInfo.txt appears (it is
   # written after the fq.gz copy completes).
   RUN_FASTQ=$SEQ_ROOT/$RUN/$LANE/${RUN}_${LANE}_read.fq.gz
   FILE_INFO=$SEQ_ROOT/$RUN/$LANE/${RUN}_${LANE}_FileInfo.txt

   echo "Checking run is completed (Sequencing Status in RunInfoMetrics.csv, and $FILE_INFO)..."

   RUN_STATUS=$(grep '^Sequencing Status,' "$RUN_INFO" | head -1 | cut -d, -f2 | tr -d '\r')
   RUN_INCOMPLETE=0
   if [ "$RUN_STATUS" != "Success" ]; then
      echo "Warning: Sequencing Status is '$RUN_STATUS' (expected 'Success')."
      RUN_INCOMPLETE=1
   fi
   if [ ! -f "$FILE_INFO" ]; then
      echo "Warning: $FILE_INFO does not exist, the fastq for $LANE may still be copying."
      RUN_INCOMPLETE=1
   fi
   if [ ! -f "$RUN_FASTQ" ]; then
      echo "Warning: $RUN_FASTQ does not exist."
      RUN_INCOMPLETE=1
   fi

   if [ $RUN_INCOMPLETE != 0 ]; then
      echo "This run has not completed sequencing or uploading! Are you SURE you want to continue? (y/n; default=n)"
      read_answer_with_default n
      if [ "$answer" != "y" ]; then
         echo "OK, quitting..."
         exit 1
      else
         echo "OK, will continue..."
      fi
   fi

   mkdir -p $OUTPUT_ROOT/logs

   if [ ! -d $OUTPUT_ROOT/logs ]; then
      echo "Error: could not create output folder $OUTPUT_ROOT/logs. Quitting."
      exit 1
   fi

   # Keep a copy of the sample sheet with the outputs, and run from that copy so
   # any edits made here are what the pipeline actually sees.
   if [ ! -f $OUTPUT_ROOT/SampleSheet.csv ]; then
      echo "Copying $SAMPLE_SHEET to $OUTPUT_ROOT/SampleSheet.csv "
      cp $SAMPLE_SHEET $OUTPUT_ROOT/SampleSheet.csv
   fi

   echo "
  Using sample sheet $OUTPUT_ROOT/SampleSheet.csv for splitBarcode.
  Please review and edit this sample sheet, making any necessary changes for batch processing.

  The [Data] section needs Sample_ID, index (i7) and index2 (i5). The barcode
  file for splitBarcode is generated from these as index+index2.

  Unlike bcl-convert, no OverrideCycles or other geometry needs to be declared:
  the read geometry is measured from the fastq itself and then validated against
  the sample sheet before demultiplexing runs. If the offsets are wrong, or the
  sample sheet does not belong to this run, prepare_barcodes will fail loudly
  rather than produce a bad demultiplex.

  Notes:
    - All index and index2 sequences must be the same length within a run.
    - Sample_ID and the index+index2 pair must both be unique.
    - Remove any samples not part of this batch.
  "
   echo "Press Enter to review sample sheet in vim."
   read_answer_with_default ""

   vim $OUTPUT_ROOT/SampleSheet.csv

   echo "Proceed with updated SampleSheet.csv? (y/n; default=y):"
   read_answer_with_default y
   if [ "$answer" != "y" ]; then
      echo "OK, quitting..."
      exit 1
   fi

   ###### ensure output folder does not exist
   if [ -d $OUTPUT_ROOT/splitbarcode ]; then
      echo "Error: $OUTPUT_ROOT/splitbarcode already exists, please clean up and retry."
      exit 1
   fi

   SMK_CONFIG="OUT_ROOT=$OUTPUT_ROOT IN_ROOT=$SEQ_ROOT RUN=$RUN LANE=$LANE SAMPLE_SHEET=$OUTPUT_ROOT/SampleSheet.csv"

   echo "
About to run sequence production and MultiQC generation using:

snakemake --profile $SMK_CONFIG_DIR --snakefile workflow/wgs_prism.smk --config $SMK_CONFIG

OK? (y/n; default=y):
"

   read_answer_with_default y
   if [ "$answer" != "y" ]; then
      echo "OK, quitting..."
      exit 1
   fi
   echo "Starting..."

   echo "snakemake --profile $SMK_CONFIG_DIR --snakefile workflow/wgs_prism.smk --config $SMK_CONFIG "

   snakemake --profile $SMK_CONFIG_DIR --snakefile workflow/wgs_prism.smk --config $SMK_CONFIG 2>&1 | tee "$OUTPUT_ROOT/logs/wgs_prism.log"

   if [ ${PIPESTATUS[0]} != 0 ]; then
      echo "Error: wgs_prism run failed. Check the logs under $OUTPUT_ROOT/logs/ :"
      echo "  - wgs_prism.log                : snakemake orchestration log (this run)"
      echo "  - prepare_barcodes.log         : barcode file generation and the geometry validation gate"
      echo "  - run_splitbarcode.log         : splitBarcode arguments, stdout/stderr and its log/"
      echo "  - splitbarcode_Logs/           : splitBarcode log/ (preserved on failure)"
      echo "  - run_fastqc.log               : FastQC over the demultiplexed fastq"
      echo "  - barcodestat_to_mqc.log, run_multiqc.log : per-step logs"
      echo "  - slurm/                       : per-job SLURM output"
      exit 1
   fi

   echo "Success: wgs_prism run for $RUN completed. Outputs under $OUTPUT_ROOT/ :"
   echo "  - multiqc/$RUN.multiqc.html  : MultiQC report (open this first)"
   echo "  - multiqc/multiqc_data/      : MultiQC parsed data (tsv)"
   echo "  - multiqc/splitbarcode_mqc.tsv : per-sample demultiplexing rates"
   echo "  - splitbarcode/              : demultiplexed FASTQ files (.fq.gz)"
   echo "  - splitbarcode/BarcodeStat.txt : splitBarcode demultiplexing summary"
   echo "  - fastqc/                    : per-sample FastQC reports"
   echo "  - $RUN.barcode               : barcode file generated from the sample sheet"
   echo "  - splitbarcode_params.json   : validated read geometry used for demultiplexing"
   echo "  - logs/                      : per-step run logs"
   echo "  - benchmarks/                : per-step runtime/memory benchmarks"

}


get_opts "$@"
get_run_opts
